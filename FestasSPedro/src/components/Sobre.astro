                                    {pessoa.Foto && pessoa.Foto !== '-' ? (
                                        <img src={pessoa.Foto} alt={pessoa.Nome} class={`${(categoria.Categoria === "Top 6 Apoiadores") ? "object-contain p-2" : "object-cover"} w-full h-full`} />
                                    ) : (
                                        <svg xmlns="http://www.w3.org/2000/svg" class="h-14 w-14 text-blue-900/40" viewBox="0 0 20 20" fill="currentColor">
                                            <path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" clip-rule="evenodd" />
                                        </svg>
                                    )}
                                </div>
                                {categoria.Categoria !== "Patrocinadores Oficiais" && (
                                    <>
                                        <h3 class="sm:text-xl font-semibold text-blue-900">{pessoa.Nome}</h3>
                                        {pessoa.Categorias && (
                                            <div class="flex flex-wrap justify-center gap-1 mt-2">
                                                {pessoa.Categorias.split(', ').map((categoria) => (
                                                    <span class="inline-block bg-blue-100 text-blue-800 px-2 py-1 rounded-full text-xs font-medium">
                                                        {categoria}
                                                    </span>
                                                ))}
                                            </div>
                                        )}
                                    </>
                                )}
                            </div>
                        ))}
                    </div>
                </div>
            ))}
        </div>


    </section>
</div>


<script>
function shuffle<T>(array: T[]): T[] {
    const shuffled = [...array];
    for (let i = shuffled.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        [shuffled[i], shuffled[j]] = [shuffled[j], shuffled[i]];
    }
    return shuffled;
}

document.addEventListener('DOMContentLoaded', () => {
    const equipaGrid = document.getElementById('equipa-grid');
    if (equipaGrid) {
        const children = Array.from(equipaGrid.children) as HTMLElement[];
        const lastElement = children.pop();

        const normals = children.filter(child => child.classList.contains('from-blue-800'));
        const extras = children.filter(child => !child.classList.contains('from-blue-800'));

        const shuffledNormals = shuffle(normals);
        const shuffledExtras = shuffle(extras);

        equipaGrid.innerHTML = '';
        shuffledNormals.forEach(child => equipaGrid.appendChild(child));
        shuffledExtras.forEach(child => equipaGrid.appendChild(child));
        if (lastElement) equipaGrid.appendChild(lastElement);
    }

    // Lógica do Botão de Toggle (Abrir/Fechar Filtros)
    const toggleBtn = document.getElementById('toggle-filters-btn');
    const filtersContainer = document.getElementById('filters-container');
    const filterArrow = document.getElementById('filter-arrow');

    if (toggleBtn && filtersContainer && filterArrow) {
        toggleBtn.addEventListener('click', () => {
            filtersContainer.classList.toggle('hidden');
            filtersContainer.classList.toggle('flex');
            filterArrow.classList.toggle('rotate-180');
        });
    }

    // Lógica de Filtragem
    const filterBtns = document.querySelectorAll('.filter-btn');
    
    filterBtns.forEach(btn => {
        btn.addEventListener('click', () => {
            // Atualizar estilo dos botões
            filterBtns.forEach(b => {
                b.classList.remove('bg-blue-50', 'text-blue-900', 'font-bold');
                b.classList.add('text-gray-600', 'font-medium');
            });
            btn.classList.remove('text-gray-600', 'font-medium');
            btn.classList.add('bg-blue-50', 'text-blue-900', 'font-bold');

            const filter = btn.getAttribute('data-filter');
            const cards = document.querySelectorAll('#equipa-grid > div');

            cards.forEach(card => {
                const categories = card.getAttribute('data-categories');
                if (filter === 'all' || (categories && categories.includes(filter))) {
                    card.classList.remove('hidden');
                    card.classList.add('flex');
                } else {
                    card.classList.add('hidden');
                    card.classList.remove('flex');
                }
            });

            // Fechar dropdown após seleção
            filtersContainer.classList.add('hidden');
            filtersContainer.classList.remove('flex');
            filterArrow.classList.remove('rotate-180');
        });
    });

});
</script>
