---
<!-- Popup 1: Arraial (Direita) -->
<div id="popup-arraial" class="fixed bottom-4 right-4 md:bottom-8 md:right-8 z-50 max-w-sm w-full transform translate-y-full opacity-0 transition-all duration-500 ease-out pointer-events-none">
    <div class="bg-white rounded-2xl shadow-2xl border border-blue-100 p-4 m-4 md:m-0 relative overflow-hidden">
        <button id="close-popup-arraial" class="absolute top-2 right-2 text-gray-400 hover:text-blue-900 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" />
            </svg>
        </button>
        
        <div class="flex gap-4 items-center">
            <div class="w-16 h-16 flex-shrink-0 rounded-xl overflow-hidden shadow-md">
                <img src="/arraial/arraial.jpeg" alt="Grande Arraial" class="w-full h-full object-cover" />
            </div>
            <div>
                <h4 class="font-bold text-blue-900 text-base md:text-lg leading-tight">Grande Arraial</h4>
                <p class="text-xs text-gray-600 mt-0.5 mb-1.5">27 Junho • A partir das 19h</p>
                <a href="/bilheteira" class="text-xs font-bold text-blue-600 hover:text-blue-800 uppercase tracking-wide">
                    Ver Menu & Detalhes &rarr;
                </a>
            </div>
        </div>
    </div>
</div>

<!-- Popup 2: Cartaz (Esquerda) -->
<div id="popup-cartaz" class="fixed bottom-4 left-4 md:bottom-8 md:left-8 z-50 max-w-sm w-full transform translate-y-full opacity-0 transition-all duration-500 ease-out pointer-events-none">
    <div class="bg-white rounded-2xl shadow-2xl border border-blue-100 p-4 m-4 md:m-0 relative overflow-hidden">
        <button id="close-popup-cartaz" class="absolute top-2 right-2 text-gray-400 hover:text-blue-900 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" />
            </svg>
        </button>
        
        <div class="flex gap-4 items-center">
            <div class="w-16 h-16 flex-shrink-0 rounded-xl overflow-hidden shadow-md">
                <img src="/cartaz.png" alt="Mini Cartaz" class="w-full h-full object-cover" />
            </div>
            <div>
                <h4 class="font-bold text-blue-900 text-lg leading-tight">Cartaz 2026</h4>
                <p class="text-xs text-gray-600 mt-1 mb-2">Já viu os artistas confirmados?</p>
                <a href="/cartaz" class="text-xs font-bold text-blue-600 hover:text-blue-800 uppercase tracking-wide">
                    Ver Cartaz &rarr;
                </a>
            </div>
        </div>
    </div>
</div>

<script>
    const popupArraial = document.getElementById('popup-arraial');
    const closePopupArraial = document.getElementById('close-popup-arraial');

    const popupCartaz = document.getElementById('popup-cartaz');
    const closePopupCartaz = document.getElementById('close-popup-cartaz');

    // Popup Logic - Arraial
    if (popupArraial && closePopupArraial) {
        setTimeout(() => {
            popupArraial.classList.remove('translate-y-full', 'opacity-0', 'pointer-events-none');
        }, 500);

        closePopupArraial.addEventListener('click', () => {
            popupArraial.classList.add('translate-y-full', 'opacity-0', 'pointer-events-none');
        });
    }

    // Popup Logic - Cartaz
    if (popupCartaz && closePopupCartaz) {
        setTimeout(() => {
            popupCartaz.classList.remove('translate-y-full', 'opacity-0', 'pointer-events-none');
        }, 1000); // Aparece 1 segundo depois do primeiro

        closePopupCartaz.addEventListener('click', () => {
            popupCartaz.classList.add('translate-y-full', 'opacity-0', 'pointer-events-none');
        });
    }
</script>