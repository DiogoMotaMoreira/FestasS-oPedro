<style>
    .no-scrollbar::-webkit-scrollbar { display: none; }
    .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
    
    .text-center-last {
        text-align-last: center;
    }
</style>

<script>
function shuffle<T>(array: T[]): T[] {
    const shuffled = [...array];
    for (let i = shuffled.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        [shuffled[i], shuffled[j]] = [shuffled[j], shuffled[i]];
    }
    return shuffled;
}

function initSobre() {
    const equipaGrid = document.getElementById('equipa-grid');
    if (equipaGrid) {
        const children = Array.from(equipaGrid.children) as HTMLElement[];
        
        // Guarda o card "Em breve..." para meter no fim, se existir
        const emBreveIndex = children.findIndex(c => c.textContent?.includes('Em breve'));
        let emBreveCard = null;
        if (emBreveIndex > -1) {
            emBreveCard = children.splice(emBreveIndex, 1)[0];
        }
        
        const shuffledCards = shuffle(children);

        equipaGrid.innerHTML = '';
        shuffledCards.forEach(child => equipaGrid.appendChild(child));
        if (emBreveCard) equipaGrid.appendChild(emBreveCard);
    }

    // Lógica de Filtragem (Dropdown)
    const filterSelect = document.getElementById('equipa-filter');
    if (filterSelect) {
        filterSelect.addEventListener('change', (e) => {
            const filter = (e.target as HTMLSelectElement).value;
            const cards = document.querySelectorAll('.equipa-card');

            cards.forEach(card => {
                const categories = card.getAttribute('data-categories');
                if (filter === 'all' || (categories && categories.includes(filter))) {
                    (card as HTMLElement).style.display = 'flex';
                } else {
                    (card as HTMLElement).style.display = 'none';
                }
            });
        });
    }
    
    // Lógica do Modal
    const cards = document.querySelectorAll('.equipa-card');
    const modal = document.getElementById('membro-modal');
    const modalContent = document.getElementById('membro-modal-content');
    const closeBtn = document.getElementById('close-membro-modal');
    const modalFoto = document.getElementById('modal-foto') as HTMLImageElement;
    const modalFotoFallback = document.getElementById('modal-foto-fallback');
    const modalNome = document.getElementById('modal-nome');
    const modalCategorias = document.getElementById('modal-categorias');

    function openModal(nome: string, foto: string, categoriasStr: string) {
        if (!modal || !modalContent || !modalNome || !modalFoto || !modalFotoFallback || !modalCategorias) return;
        
        modalNome.textContent = nome;
        
        if (foto) {
            modalFoto.src = foto;
            modalFoto.classList.remove('hidden');
            modalFotoFallback.classList.add('hidden');
        } else {
            modalFoto.src = '';
            modalFoto.classList.add('hidden');
            modalFotoFallback.classList.remove('hidden');
        }

        modalCategorias.innerHTML = '';
        if (categoriasStr) {
            const cats = categoriasStr.split(',');
            cats.forEach(cat => {
                if (!cat.trim()) return;
                const span = document.createElement('span');
                span.className = 'px-3 py-1 bg-blue-100 text-blue-800 rounded-full text-[10px] font-bold uppercase tracking-wider shadow-sm';
                span.textContent = cat.trim();
                modalCategorias.appendChild(span);
            });
        } else {
            const span = document.createElement('span');
            span.className = 'px-3 py-1 bg-blue-100 text-blue-800 rounded-full text-[10px] font-bold uppercase tracking-wider shadow-sm';
            span.textContent = 'Apoio Geral';
            modalCategorias.appendChild(span);
        }

        modal.classList.remove('hidden');
        void modal.offsetWidth; // Força reflow (animação)
        modal.classList.remove('opacity-0');
        modalContent.classList.remove('scale-95');
        modalContent.classList.add('scale-100');
        document.body.style.overflow = 'hidden';
    }

    function closeModal() {
        if (!modal || !modalContent) return;
        modal.classList.add('opacity-0');
        modalContent.classList.remove('scale-100');
        modalContent.classList.add('scale-95');
        setTimeout(() => {
            modal.classList.add('hidden');
            document.body.style.overflow = '';
        }, 300);
    }

    cards.forEach(card => {
        card.addEventListener('click', () => {
            const nome = card.getAttribute('data-nome') || '';
            const foto = card.getAttribute('data-foto') || '';
            const cats = card.getAttribute('data-categories') || '';
            openModal(nome, foto, cats);
        });
    });

    closeBtn?.addEventListener('click', closeModal);
    modal?.addEventListener('click', (e) => {
        if (e.target === modal) closeModal();
    });
    document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && modal && !modal.classList.contains('hidden')) closeModal();
    });
}

if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initSobre);
} else {
    initSobre();
}
document.addEventListener('astro:page-load', initSobre);
</script>
