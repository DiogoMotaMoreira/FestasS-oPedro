// Extrair categorias únicas da equipa para o filtro
const equipaGroup = grupo.find(g => g.Categoria === "Equipa");
const categoriasSet = new Set();
if (equipaGroup) {
    equipaGroup.Pessoas.forEach(p => {
        if (p.Categorias) p.Categorias.split(',').forEach(c => categoriasSet.add(c.trim()));
    });
}
const categoriasUnicas = Array.from(categoriasSet).sort();
---

<div class="min-h-screen relative flex flex-col items-center justify-center px-2 sm:px-6 md:px-12 bg-gradient-to-br from-blue-500 via-blue-200 to-yellow-400">
    <!-- Conteúdo principal -->
    <section class="flex flex-col items-center justify-center text-center my-32 space-y-12 max-w-6xl px-4">
        <!-- Introdução -->
        <div class="space-y-6">
            <h1 class="text-5xl md:text-6xl font-bold text-blue-900 drop-shadow-lg">
                Sobre Nós
            </h1>
            <p class="text-lg md:text-xl text-blue-900/90 drop-shadow-md max-w-3xl mx-auto">
                Somos a alma das Festas de São Pedro de Caíde de Rei — um grupo de amigos, vizinhos e apaixonados pelas tradições populares portuguesas que trabalha arduamente para manter viva a chama da nossa cultura e da nossa terra.
            </p>
        </div>

        <!-- Grupos e pessoas -->
        <div class="w-full flex flex-col gap-10">
            {grupo.map((categoria) => (
                <div class="space-y-6">
                    {categoria.Categoria === "Equipa" ? (
                        <div class="relative flex flex-col md:flex-row items-center justify-center mb-4 w-full z-30">
                            <h2 class="text-3xl md:text-4xl font-extrabold text-blue-900 text-center drop-shadow mb-4 md:mb-0">
                                {categoria.Categoria}
                            </h2>
                            <div class="md:absolute md:right-0 md:top-1/2 md:-translate-y-1/2 relative">
                                <button id="toggle-filters-btn" class="px-4 py-2 rounded-xl bg-white text-blue-900 font-bold shadow-md transition-all hover:shadow-lg border border-blue-100 flex items-center gap-2 group text-sm md:text-base">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z" />
                                    </svg>
                                    <span>Filtrar</span>
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 transition-transform duration-300 ml-1 text-blue-400 group-hover:text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" id="filter-arrow">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                                    </svg>
                                </button>
                                
                                <div id="filters-container" class="hidden absolute right-0 mt-2 w-64 bg-white rounded-xl shadow-2xl border border-blue-100 flex-col overflow-hidden z-50 origin-top-right">
                                    <button class="filter-btn active w-full text-left px-5 py-3 text-sm font-bold text-blue-900 bg-blue-50 hover:bg-blue-100 transition-colors border-b border-gray-100 flex justify-between items-center" data-filter="all">
                                        Todos
                                    </button>
