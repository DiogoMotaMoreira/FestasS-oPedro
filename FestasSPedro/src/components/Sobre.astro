                                        <button class="filter-btn w-full text-left px-5 py-3 text-sm font-medium text-gray-600 hover:bg-blue-50 hover:text-blue-900 transition-colors border-b border-gray-50 last:border-0" data-filter={cat}>
                                            {cat}
                                        </button>
                                    ))}
                                </div>
                            </div>
                        </div>
                    ) : (
                        (categoria.Pessoas.length!==0) && (categoria.Categoria != "Equipa Extra") && (
