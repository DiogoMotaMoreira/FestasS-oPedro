                                        </svg>
                                    </div>
                                )}
                            </div>
                            <div class="flex-1 min-w-0 pointer-events-none">
                                <h4 class="font-bold text-blue-900 text-sm truncate leading-tight">{pessoa.Nome}</h4>
                            </div>
