---
import BaseLayout from '../layouts/BaseLayout.astro';
import PurchaseInstructions from '../components/PurchaseInstructions.astro';
import RifaCard from '../components/RifaCard.astro';
---

<BaseLayout title="Festas São Pedro">
    <main class="min-h-screen bg-gradient-to-br from-blue-500 via-blue-200 to-yellow-400 pt-32 py-16 flex justify-center items-start">
        <div class="container mx-auto px-4 md:px-8 lg:px-12">
            <div class="max-w-6xl mx-auto space-y-12">
                
                <!-- Cabeçalho da Secção -->
                <div class="text-center space-y-4">
                    <h1 class="text-4xl md:text-6xl font-black text-blue-900 drop-shadow-sm tracking-tight">
                        Bilheteira & Rifas
                    </h1>
                    <p class="text-xl text-blue-900/80 font-medium max-w-2xl mx-auto">
                        Apoie as Festas de São Pedro e habilite-se a ganhar prémios incríveis.
                    </p>
                </div>

                <div class="grid grid-cols-1 gap-10">
                    <!-- Card Rifa Premium -->
                    <RifaCard type="full" />

                    <!-- Adicionar mais rifas se necessário -->
                </div>

                <div class="mt-16 text-center">
                    <div class="inline-block bg-white/40 backdrop-blur-md rounded-2xl p-8 border border-white/50 shadow-lg">
                        <h2 class="text-2xl font-bold text-blue-900 mb-2">Bilhetes para Eventos</h2>
                        <p class="text-blue-800">A bilheteira para os concertos e eventos abrirá brevemente.</p>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <!-- Modal -->
    <div id="modal" class="fixed inset-0 bg-blue-900/80 backdrop-blur-sm flex items-center justify-center z-50 hidden transition-opacity duration-300 ease-in-out opacity-0 pointer-events-none p-4">
        <div class="bg-white rounded-3xl shadow-2xl w-full max-w-5xl max-h-[90vh] overflow-y-auto transform scale-95 transition-transform duration-300 ease-in-out flex flex-col">
            
            <!-- Modal Header -->
            <div class="sticky top-0 bg-white/95 backdrop-blur z-10 px-8 py-6 border-b border-gray-100 flex justify-between items-center">
                <h2 class="text-2xl md:text-3xl font-bold text-blue-900">Detalhes do Cruzeiro</h2>
                <button id="close-modal" class="p-2 rounded-full hover:bg-gray-100 text-gray-500 hover:text-blue-900 transition-colors">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                    </svg>
                </button>
            </div>
            
            <div class="p-8 space-y-10">
                <!-- Hero Section Modal -->
                <div class="flex flex-col md:flex-row gap-8 items-start">
                    <div class="w-full md:w-1/2 space-y-6">
                        <img src="/Rifas/MSC-Opera.webp" alt="MSC-Opera" class="rounded-2xl w-full h-auto shadow-lg" />
                        <div class="rounded-2xl overflow-hidden shadow-lg">
                            <iframe class="w-full aspect-video" src="https://www.youtube.com/embed/e8wi6lQuHW8" title="MSC Opera Video" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" allowfullscreen></iframe>
                        </div>
                    </div>
                    <div class="w-full md:w-1/2 space-y-4">
                        <div class="inline-block px-3 py-1 bg-yellow-100 text-yellow-800 rounded-full text-sm font-bold mb-2">MSC OPERA</div>
                        <h3 class="text-2xl font-bold text-blue-900">Experiência Mediterrânea</h3>
                        <p class="text-gray-600 leading-relaxed">
                            Desfrute de 11 dias inesquecíveis com partida e chegada a Lisboa. 
                            Este pacote exclusivo inclui todas as taxas portuárias e um pack de bebidas para que não tenha de se preocupar com nada.
                        </p>
                        
                        <div class="grid grid-cols-2 gap-4 mt-4">
                            <div class="bg-blue-50 p-4 rounded-xl">
                                <p class="text-xs text-blue-500 uppercase font-bold">Partida</p>
                                <p class="text-blue-900 font-semibold">07 Junho 2026</p>
                            </div>
                            <div class="bg-blue-50 p-4 rounded-xl">
                                <p class="text-xs text-blue-500 uppercase font-bold">Chegada</p>
                                <p class="text-blue-900 font-semibold">17 Junho 2026</p>
                            </div>
                        </div>

                        <div class="pt-4 border-t border-gray-100 mt-4">
                            <p class="text-sm text-gray-500 mb-1">Sorteio Público</p>
                            <p class="text-blue-900 font-medium">Dia 02/05/2026 às 18h00 (Fim da missa)</p>
                            <p class="text-xs text-gray-400">Transmissão em direto no jornal e TV local</p>
                        </div>
                    </div>
                </div>

                <!-- Itinerário -->
                <div class="bg-gray-50 rounded-3xl p-6 md:p-8">
                    <h3 class="text-xl font-bold text-blue-900 mb-6 flex items-center gap-2">
                        <span class="text-2xl">🚢</span> Itinerário Detalhado
                    </h3>
                    
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-8">
                        <!-- Coluna 1 -->
                        <div class="space-y-6 relative">
                            <!-- Linha vertical -->
                            <div class="absolute left-[7px] top-2 bottom-2 w-0.5 bg-gray-200"></div>
                            
                            <!-- Items -->
                            <div class="relative pl-8">
                                <div class="absolute left-0 top-1.5 w-4 h-4 rounded-full bg-yellow-400 border-2 border-white shadow-sm"></div>
                                <h4 class="font-bold text-blue-900">Dia 1: Lisboa</h4>
                                <p class="text-sm text-gray-600">07 Junho • Partida 18h00</p>
                            </div>
                            <div class="relative pl-8">
                                <div class="absolute left-0 top-1.5 w-4 h-4 rounded-full bg-blue-200 border-2 border-white"></div>
                                <h4 class="font-bold text-blue-900">Dia 2: Navegação</h4>
                                <p class="text-sm text-gray-600">08 Junho • Relaxamento</p>
                            </div>
                            <div class="relative pl-8">
                                <div class="absolute left-0 top-1.5 w-4 h-4 rounded-full bg-blue-500 border-2 border-white"></div>
                                <h4 class="font-bold text-blue-900">Dia 3: Alicante, Espanha</h4>
                                <p class="text-sm text-gray-600">09 Junho • 09h00 - 17h00</p>
                            </div>
                            <div class="relative pl-8">
                                <div class="absolute left-0 top-1.5 w-4 h-4 rounded-full bg-blue-500 border-2 border-white"></div>
                                <h4 class="font-bold text-blue-900">Dia 4: Mahon, Menorca</h4>
                                <p class="text-sm text-gray-600">10 Junho • 09h00 - 16h00</p>
                            </div>
                            <div class="relative pl-8">
                                <div class="absolute left-0 top-1.5 w-4 h-4 rounded-full bg-blue-500 border-2 border-white"></div>
                                <h4 class="font-bold text-blue-900">Dia 5: Olbia, Itália</h4>
                                <p class="text-sm text-gray-600">11 Junho • 10h00 - 19h00</p>
                            </div>
                            <div class="relative pl-8">
                                <div class="absolute left-0 top-1.5 w-4 h-4 rounded-full bg-blue-500 border-2 border-white"></div>
                                <h4 class="font-bold text-blue-900">Dia 6: Genova, Itália</h4>
                                <p class="text-sm text-gray-600">12 Junho • 09h00 - 18h00</p>
                            </div>
                        </div>
                        
                        <!-- Coluna 2 -->
                        <div class="space-y-6 relative">
                             <!-- Linha vertical -->
                             <div class="absolute left-[7px] top-2 bottom-2 w-0.5 bg-gray-200"></div>

                            <div class="relative pl-8">
                                <div class="absolute left-0 top-1.5 w-4 h-4 rounded-full bg-blue-500 border-2 border-white"></div>
                                <h4 class="font-bold text-blue-900">Dia 7: Marselha, França</h4>
                                <p class="text-sm text-gray-600">13 Junho • 09h00 - 17h00</p>
                            </div>
                            <div class="relative pl-8">
                                <div class="absolute left-0 top-1.5 w-4 h-4 rounded-full bg-blue-200 border-2 border-white"></div>
                                <h4 class="font-bold text-blue-900">Dia 8: Navegação</h4>
                                <p class="text-sm text-gray-600">14 Junho • Relaxamento</p>
                            </div>
                            <div class="relative pl-8">
                                <div class="absolute left-0 top-1.5 w-4 h-4 rounded-full bg-blue-500 border-2 border-white"></div>
                                <h4 class="font-bold text-blue-900">Dia 9: Málaga, Espanha</h4>
                                <p class="text-sm text-gray-600">15 Junho • 08h00 - 18h00</p>
                            </div>
                            <div class="relative pl-8">
                                <div class="absolute left-0 top-1.5 w-4 h-4 rounded-full bg-blue-500 border-2 border-white"></div>
                                <h4 class="font-bold text-blue-900">Dia 10: Cádis, Espanha</h4>
                                <p class="text-sm text-gray-600">16 Junho • 07h00 - 17h00</p>
                            </div>
                            <div class="relative pl-8">
                                <div class="absolute left-0 top-1.5 w-4 h-4 rounded-full bg-yellow-400 border-2 border-white shadow-sm"></div>
                                <h4 class="font-bold text-blue-900">Dia 11: Lisboa</h4>
                                <p class="text-sm text-gray-600">17 Junho • Chegada 09h00</p>
                            </div>
                        </div>
                    </div>
                    
                    <div class="mt-8">
                        <img src="/Rifas/itinerario.webp" alt="Mapa do Itinerário" class="rounded-xl w-full h-auto shadow-md border border-gray-200">
                    </div>
                </div>
            </div>
        </div>
    </div>


    <!-- Purchase Instructions Modal -->
    <div id="purchase-modal" class="fixed inset-0 bg-blue-900/80 backdrop-blur-sm flex items-center justify-center z-50 hidden transition-opacity duration-300 ease-in-out opacity-0 pointer-events-none p-4">
        <div class="bg-white rounded-3xl shadow-2xl w-full max-w-2xl max-h-[90vh] overflow-y-auto transform scale-95 transition-transform duration-300 ease-in-out flex flex-col">
            
            <!-- Modal Header -->
            <div class="sticky top-0 bg-white/95 backdrop-blur z-10 px-8 py-6 border-b border-gray-100 flex justify-between items-center">
                <h2 class="text-2xl font-bold text-blue-900">Como Comprar</h2>
                <button id="close-purchase-modal" class="p-2 rounded-full hover:bg-gray-100 text-gray-500 hover:text-blue-900 transition-colors">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                    </svg>
                </button>
            </div>
            
            <div class="p-8">
                <PurchaseInstructions />
            </div>
        </div>
    </div>

</BaseLayout>

<script>
const verMaisBtn = document.getElementById('ver-mais-btn');
const modal = document.getElementById('modal');
const modalContent = modal?.querySelector('div');
const closeModal = document.getElementById('close-modal');

const comprarAgoraBtn = document.getElementById('comprar-agora-btn');
const purchaseModal = document.getElementById('purchase-modal');
const purchaseModalContent = purchaseModal?.querySelector('div');
const closePurchaseModal = document.getElementById('close-purchase-modal');

function toggleModal(modalElement, contentElement, show) {
    if (!modalElement || !contentElement) return;
    
    if (show) {
        modalElement.classList.remove('hidden');
        // Force reflow
        void modalElement.offsetWidth;
        modalElement.classList.remove('opacity-0');
        modalElement.classList.remove('pointer-events-none');
        
        contentElement.classList.remove('scale-95');
        contentElement.classList.add('scale-100');
    } else {
        modalElement.classList.add('opacity-0');
        modalElement.classList.add('pointer-events-none');
        
        contentElement.classList.remove('scale-100');
        contentElement.classList.add('scale-95');
        
        setTimeout(() => {
            modalElement.classList.add('hidden');
        }, 300);
    }
}

if (verMaisBtn && modal && closeModal) {
    verMaisBtn.addEventListener('click', () => {
        toggleModal(modal, modalContent, true);
    });

    closeModal.addEventListener('click', () => {
        toggleModal(modal, modalContent, false);
    });

    modal.addEventListener('click', (e) => {
        if (e.target === modal) {
            toggleModal(modal, modalContent, false);
        }
    });
}

if (comprarAgoraBtn && purchaseModal && closePurchaseModal) {
    comprarAgoraBtn.addEventListener('click', () => {
        toggleModal(purchaseModal, purchaseModalContent, true);
    });

    closePurchaseModal.addEventListener('click', () => {
        toggleModal(purchaseModal, purchaseModalContent, false);
    });

    purchaseModal.addEventListener('click', (e) => {
        if (e.target === purchaseModal) {
            toggleModal(purchaseModal, purchaseModalContent, false);
        }
    });
}
</script>
