---
<div class="min-h-screen bg-gradient-to-br from-blue-500 via-blue-200 to-yellow-400 flex flex-col items-center">
    <!-- Header -->
    <header class="absolute top-6 w-full flex justify-between items-center px-6 md:px-12 z-50">
        <a href="/" class="flex items-center">
            <img src="/sp_logo.webp" alt="Logo Festas São Pedro" class="h-16 md:h-20" />
        </a>

        <!-- Botão hamburger para mobile -->
        <button id="menu-btn" class="md:hidden ml-auto flex flex-col space-y-1.5 text-blue-900 focus:outline-none">
            <span class="block w-6 h-0.5 bg-blue-900"></span>
            <span class="block w-6 h-0.5 bg-blue-900"></span>
            <span class="block w-6 h-0.5 bg-blue-900"></span>
        </button>

        <!-- Menu -->
        <nav>
            <ul id="menu" class="hidden md:flex md:space-x-8 text-blue-900 text-base md:text-lg font-medium drop-shadow-lg absolute md:static top-16 right-6 bg-white/90 md:bg-transparent p-6 md:p-0 rounded-lg md:rounded-none flex-col md:flex-row gap-4 md:gap-0">
                <li><a href="/" class="hover:text-blue-600 transition block text-end">Home</a></li>
                <li><a href="/eventos" class="hover:text-blue-600 transition block text-end">Eventos</a></li>
                <li><a href="/cartaz" class="hover:text-blue-600 transition block text-end">Cartaz</a></li>
                <li><a href="/sobre" class="hover:text-blue-600 transition block text-end">Sobre nós</a></li>
                <li><a href="/help" class="bg-white text-blue-600 px-4 py-2 rounded-lg hover:bg-gray-100 transition block text-center">Quero Ajudar!</a></li>
            </ul>
        </nav>
    </header>

    <!-- Conteúdo -->
    <section class="flex flex-col items-center justify-center flex-1 my-32 w-full px-6 md:px-12">
        <div class="w-full max-w-6xl grid grid-cols-1 lg:grid-cols-3 gap-8">
            <!-- Eventos -->
            <div class="lg:col-span-2 order-1 lg:order-none">
                <!-- Abas (Meses) -->
                <div id="tabs" class="flex flex-wrap gap-2 mb-6 justify-center"></div>

                <!-- Lista de eventos -->
                <div id="eventos-container" class="bg-white/70 p-6 rounded-lg shadow-lg">
                    <ol id="eventos-list" class="relative border-l-4 border-yellow-400"></ol>
                </div>
            </div>

            <!-- Tempo e localização -->
            <div class="lg:col-span-1 order-2 lg:order-none">
                <div id="tempo-agora" class="text-blue-900 p-6 bg-white/90 rounded-lg shadow-lg mb-6">
                    <h3 class="font-bold text-2xl mb-4 border-b-2 border-yellow-400 pb-2">Tempo para hoje</h3>
                    <div class="flex flex-col space-y-4 text-blue-900 text-lg">
                      <div class="flex items-center justify-between">
                        <div class="flex items-center space-x-2">
                          <span class="text-2xl">🌡️</span>
                          <span>Temperatura:</span>
                        </div>
                        <div id="temp-range" class="font-semibold"></div>
                      </div>

                      <div class="flex items-center justify-between">
                        <div class="flex items-center space-x-2">
                          <span class="text-2xl">🌧️</span>
                          <span>Precipitação:</span>
                        </div>
                        <div id="precip-prob" class="font-semibold"></div>
                      </div>
                    </div>
                </div>

                <!-- Como nos encontrar -->
                <div class="text-blue-900 p-6 bg-white/90 rounded-lg shadow-lg mb-6">
                    <h3 class="font-bold text-2xl mb-4 border-b-2 border-yellow-400 pb-2">Como nos encontrar</h3>
                    <div class="text-lg">
                        <p class="mb-4"><strong>Endereço:</strong></p>
                        <p>Avenida Padre Fernando da Cunha Carvalho 184, Caíde de Rei, Portugal, 4620-073</p>
                        <div class="mt-4">
                            <iframe src="https://www.google.com/maps/embed?pb=!1m17!1m12!1m3!1d2998.9074031102446!2d-8.225749!3d41.267351999999995!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m2!1m1!2zNDHCsDE2JzAyLjUiTiA4wrAxMyczMi43Ilc!5e0!3m2!1spt-PT!2spt!4v1758147606870!5m2!1spt-PT!2spt" width="100%" height="200" style="border:0;" allowfullscreen="" loading="lazy"></iframe>
                        </div>
                    </div>
                </div>

                <div>
                    <p class="text-center text-xl font-medium text-blue-900 p-4"><span class="text-red-600">Aviso:</span> Qualquer evento, data e hora podem ser alterados a qualquer momento devido a fatores externos (ex. meteorologia)!</p>
                </div>
            </div>


        </div>
    </section>
</div>

<script src="/events.js" is:inline></script>

<script is:inline>
function agruparPorMes(eventos) {
    const grupos = {};
    eventos.forEach(evento => {
        const chave = `${evento.mes} ${evento.ano}`;
        if (!grupos[chave]) grupos[chave] = [];
        grupos[chave].push(evento);
    });
    return grupos;
}

const tabsContainer = document.getElementById('tabs');
const lista = document.getElementById('eventos-list');
const eventosPorMes = agruparPorMes(eventos);
const meses = Object.keys(eventosPorMes);

// Criar botões para cada mês
const now = new Date();
const diaAtual = now.getDay();
const mesAtual = now.getMonth(); // 0 = Janeiro
const anoAtual = now.getFullYear();

// Mapa para converter nome do mês PT → número (0-11)
const mapaMeses = {
    "Janeiro": 0,
    "Fevereiro": 1,
    "Março": 2,
    "Abril": 3,
    "Maio": 4,
    "Junho": 5,
    "Julho": 6,
    "Agosto": 7,
    "Setembro": 8,
    "Outubro": 9,
    "Novembro": 10,
    "Dezembro": 11
};

// Todos os meses
const mesesFiltrados = meses.filter(mes => mes.includes('2025'));

// Nomes dos meses em português
const monthNames = ["Janeiro", "Fevereiro", "Março", "Abril", "Maio", "Junho", "Julho", "Agosto", "Setembro", "Outubro", "Novembro", "Dezembro"];
const currentMonthName = monthNames[mesAtual];
const currentMonthKey = `${currentMonthName} 2025`;

// Criar botões para todos os meses
mesesFiltrados.forEach((mesAno, idx) => {
    const btn = document.createElement('button');
    btn.textContent = mesAno;
    const isCurrentMonth = mesAno === currentMonthKey;
    btn.className = `px-4 py-2 rounded-lg font-semibold ${isCurrentMonth ? 'bg-yellow-400 text-blue-900' : 'bg-white text-blue-600'} shadow`;
    btn.addEventListener('click', () => {
        // Atualizar abas
        document.querySelectorAll('#tabs button').forEach(b => b.className = 'px-4 py-2 rounded-lg font-semibold bg-white text-blue-600 shadow');
        btn.className = 'px-4 py-2 rounded-lg font-semibold bg-yellow-400 text-blue-900 shadow';

        // Renderizar eventos
        lista.innerHTML = '';
        eventosPorMes[mesAno].forEach(evento => {
            const li = document.createElement('li');
            li.className = `ml-6 mb-8`;
            li.innerHTML = `
                <span class="absolute flex items-center justify-center w-8 h-8 ${evento.descricao != "Bar, Música e Conversas" ? 'bg-blue-900' : 'bg-yellow-400'} rounded-full -left-4 ring-4 ring-white shadow-lg"></span>
                <div class="bg-white p-4 rounded-lg shadow-md">
                    <h3 class="text-xl font-bold text-blue-900">${evento.descricao}</h3>
                    <h4 class="text-lg font-bold text-blue-900/80">${evento.extra ? evento.extra : ''}</h4>
                    <p class="text-blue-900">${evento.dia} ${evento.mes}</p>
                </div>
            `;
            lista.appendChild(li);
        });
    });
    tabsContainer.appendChild(btn);
});

// Carregar mês atual por padrão, ou primeiro se não existir
const defaultButton = Array.from(tabsContainer.querySelectorAll('button')).find(btn => btn.textContent === currentMonthKey) || tabsContainer.querySelector('button');
if (defaultButton) {
    defaultButton.click();
}

// Menu mobile toggle
const btnMenu = document.getElementById('menu-btn');
const menu = document.getElementById('menu');
btnMenu.addEventListener('click', () => {
    menu.classList.toggle('hidden');
    menu.classList.toggle('flex');
});
</script>

<script>
  async function fetchTempoAtual(cityId) {
    try {
      const res = await fetch(`https://api.ipma.pt/open-data/forecast/meteorology/cities/daily/${cityId}.json`);
      if (!res.ok) throw new Error('Erro na API IPMA: ' + res.status);
      const data = await res.json();
      // data.data é um array de previsões diárias
      const hoje = data.data[0];  // supondo que [0] é o dia atual
      return {
        maxima: hoje.tMax,
        minima: hoje.tMin,
        precipProb: hoje.precipitaProb,
        tipo: hoje.predWindDir,  // ou algum campo de tipo de tempo, ou descritivo, dependendo do que a API devolve
        vento: hoje.windSpeed,    // adaptas os nomes conforme o JSON real
      };
    } catch (err) {
      console.error(err);
      return null;
    }
  }

  async function mostraTempo(cityId) {
    const elem = document.getElementById('tempo-agora');
    const t = await fetchTempoAtual(cityId);
    if (!t) {
      elem.textContent = 'Não foi possível obter os dados meteorológicos.';
      return;
    }
    elem.querySelector('#temp-range').textContent = `${t.minima}°C — ${t.maxima}°C`;
    elem.querySelector('#precip-prob').textContent = `${t.precipProb}%`;
  }

  // Exemplo: cityId de Lisboa é 1110600? (usa o correto da lista da API)
  mostraTempo(1081505);
</script>
