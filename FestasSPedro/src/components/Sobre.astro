            <!-- CTA Patrocínios -->
            <div class="mt-12 text-center">
                <a href="/help" class="inline-flex items-center justify-center gap-2 px-8 py-4 rounded-full bg-blue-900 text-yellow-400 font-bold uppercase tracking-wide hover:bg-blue-800 hover:scale-105 transition-all shadow-xl shadow-blue-900/20">
                    <span>Quero Patrocinar</span>
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" />
