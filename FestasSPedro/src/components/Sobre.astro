                        <div class="equipa-card cursor-pointer flex items-center gap-4 p-3 bg-white/60 backdrop-blur-sm rounded-2xl shadow-sm border border-white/60 hover:bg-white hover:shadow-md hover:-translate-y-1 transition-all duration-300" data-categories={pessoa.Categorias || ""} data-nome={pessoa.Nome} data-foto={pessoa.Foto || ""}>
