<div class="min-h-screen relative flex flex-col items-center justify-center px-6 md:px-12 bg-gradient-to-br from-blue-500 via-blue-200 to-yellow-400">
    <!-- Header -->
    <header class="absolute top-6 w-full flex justify-between items-center px-6 md:px-12 z-50">
        <a href="/" class="flex items-center">
            <img src="/sp_logo.png" alt="Logo Festas São Pedro" class="h-16 md:h-20" />
        </a>

        <!-- Botão hamburger para mobile -->
        <button id="menu-btn" class="md:hidden ml-auto flex flex-col space-y-1.5 text-blue-900 focus:outline-none">
            <span class="block w-6 h-0.5 bg-blue-900"></span>
            <span class="block w-6 h-0.5 bg-blue-900"></span>
            <span class="block w-6 h-0.5 bg-blue-900"></span>
        </button>

        <!-- Menu de navegação -->
        <nav>
            <ul id="menu" class="hidden md:flex md:space-x-8 text-blue-900 text-base md:text-lg font-medium drop-shadow-lg absolute md:static top-16 right-6 bg-white/90 md:bg-transparent p-6 md:p-0 rounded-lg md:rounded-none flex-col md:flex-row gap-4 md:gap-0">
                <li><a href="/" class="hover:text-blue-600 transition block text-end">Home</a></li>
                <li><a href="/eventos" class="hover:text-blue-600 transition block text-end">Eventos</a></li>
                <li><a href="/cartaz" class="hover:text-blue-600 transition block text-end">Cartaz</a></li>
                <li><a href="/sobre" class="hover:text-blue-600 transition block text-end">Sobre nós</a></li>
                <li><a href="/help" class="bg-white text-blue-600 px-4 py-2 rounded-lg hover:bg-gray-100 transition block text-center">Quero Ajudar!</a></li>
            </ul>
        </nav>
    </header>

    <!-- Conteúdo principal -->
    <section class="flex flex-col items-center justify-center text-center mt-32 space-y-12 max-w-6xl px-4">
        <!-- Introdução -->
        <div class="space-y-6">
            <h1 class="text-5xl md:text-6xl font-bold text-blue-900 drop-shadow-lg">
                Sobre Nós
            </h1>
            <p class="text-lg md:text-xl text-blue-900/90 drop-shadow-md max-w-3xl mx-auto">
                Somos a alma das Festas de São Pedro de Caíde de Rei — um grupo de amigos, vizinhos e apaixonados pelas tradições populares portuguesas que trabalha, ano após ano, para manter viva a chama da nossa cultura e da nossa terra.
            </p>
        </div>

        <!-- Grupos e pessoas -->
        <div class="w-full flex flex-col gap-10">
            {grupo.map((categoria) => (
                <div key={categoria.Categoria} class="space-y-6">
                    <h2 class="text-3xl md:text-4xl font-extrabold text-blue-900 text-center drop-shadow">
                        {categoria.Categoria}
                    </h2>
                    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6">
                        {categoria.Pessoas.map((pessoa) => (
                            <div key={pessoa.Nome} class="flex flex-col items-center bg-white/90 rounded-2xl p-6 shadow-xl border border-white/40 hover:scale-105 transition-transform duration-200">
                                <div class="w-24 h-24 bg-blue-200/30 rounded-full flex items-center justify-center mb-4 overflow-hidden border-4 border-white shadow">
                                    {pessoa.Foto ? (
                                        <img src={pessoa.Foto} alt={pessoa.Nome} class="object-cover w-full h-full" />
                                    ) : (
                                        <span class="text-4xl font-bold text-blue-900/70">{pessoa.Nome[0]}</span>
                                    )}
                                </div>
                                <h3 class="text-xl font-semibold text-blue-900">{pessoa.Nome}</h3>
                                {pessoa.Descrição && (
                                    <p class="text-blue-900/70 text-center mt-2 text-base">{pessoa.Descrição}</p>
                                )}
                            </div>
                        ))}
                    </div>
                </div>
            ))}
        </div>
    </section>
</div>


<script>
const btn = document.getElementById('menu-btn');
const menu = document.getElementById('menu');

btn.addEventListener('click', () => {
    menu.classList.toggle('hidden');
    menu.classList.toggle('flex');
});
</script>