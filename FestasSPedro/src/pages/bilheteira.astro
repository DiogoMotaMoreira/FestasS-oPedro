---
import BaseLayout from '../layouts/BaseLayout.astro';
import PurchaseInstructions from '../components/PurchaseInstructions.astro';
---

<BaseLayout title="Festas São Pedro">
    <main class="min-h-screen bg-gradient-to-br from-blue-500 via-blue-200 to-yellow-400 pt-32 py-16 flex justify-center items-start">
        <div class="container mx-auto px-6 md:px-12 text-center">
            <div class="bg-white/80 p-8 rounded-xl shadow-lg max-w-4xl mx-auto">
                <h2 class="text-2xl md:text-3xl font-bold text-blue-900 mb-6">Rifas Disponíveis</h2>

                <div class="grid grid-cols-1 gap-8">
                    <div class="bg-gradient-to-r from-[#A68446] via-[#F2CF66] to-[#F2CF66] p-6 rounded-lg shadow-md border border-white">
                        <div class="flex flex-col md:flex-row items-center">
                            <img src="/Rifas/MSC-Opera.webp" alt="MSC-Opera" class="rounded-xl w-full md:w-1/2 h-auto mb-4 md:mb-0 md:mr-6 shadow-md" />
                            <div class="text-center md:text-left">
                                <h3 class="font-bold text-xl md:text-2xl text-blue-900 mb-2">Cruzeiro Mediterrâneo</h3>
                                <p class="text-sm md:text-base text-blue-800 mb-1"><strong>Datas:</strong> 07 Junho 2026 - 17 Junho 2026</p>
                                <p class="text-sm md:text-base text-blue-800 mb-1">Cruzeiro de 11 dias saindo de Lisboa a bordo do MSC OPERA</p>
                                <p class="text-sm md:text-base text-blue-800 mb-1">Este pack inclui todas as taxas pagas + pack de bebidas</p>
                                <p class="text-sm md:text-base text-blue-800 mb-1 font-semibold">Rota: PORTUGAL-ESPANHA-ITALIA-FRANÇA-ESPANHA-PORTUGAL</p>
                                <p class="text-sm md:text-lg font-bold text-blue-800 mb-1"><strong>Valor:</strong> 1€ por rifa</p>
                                <p class="text-xs md:text-sm text-blue-700 mt-2 mb-4">Sorteio em direto, jornal local e TV local no fim da missa dia 02/05/2026 - 18h00</p>
                                <div class="flex flex-col sm:flex-row gap-2"> 
                                    <button id="ver-mais-btn" class="bg-blue-800 text-yellow-100 px-6 py-2 rounded-lg font-semibold hover:bg-blue-700 transition shadow-md">
                                        Ver Mais
                                    </button>
                                    
                                    <button id="comprar-agora-btn" class="bg-blue-800 text-yellow-100 px-6 py-2 rounded-lg font-semibold hover:bg-blue-700 transition shadow-md">Comprar Agora</button>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Adicionar mais rifas se necessário -->
                </div>

                <div class="mt-12">
                    <h2 class="text-2xl md:text-3xl font-bold text-blue-900 mb-6">Eventos</h2>
                    <p class="text-blue-900">Informações sobre bilhetes para eventos em breve.</p>
                </div>
            </div>
        </div>
    </main>

    <!-- Modal -->
    <div id="modal" class="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50 hidden transition-opacity duration-300 ease-in-out opacity-0 pointer-events-none">
        <div class="bg-white p-10 rounded-xl shadow-xl max-w-6xl mx-4 max-h-[90vh] overflow-y-auto transform scale-95 transition-transform duration-300 ease-in-out">
            <div class="flex justify-between items-center mb-8">
                <h2 class="text-2xl md:text-3xl font-bold text-blue-900">Detalhes do Cruzeiro Mediterrâneo</h2>
                <button id="close-modal" class="text-blue-900 text-2xl font-bold">&times;</button>
            </div>
            <div class="space-y-8">
                <div>
                    <img src="/Rifas/MSC-Opera.webp" alt="MSC-Opera" class="rounded-xl w-full h-auto shadow-md mb-6" />
                    <div class="text-center">
                        <p class="text-base md:text-lg text-blue-800 mb-2"><strong>Datas:</strong> 07 Junho 2026 - 17 Junho 2026</p>
                        <p class="text-base md:text-lg text-blue-800 mb-2">Cruzeiro de 11 dias saindo de Lisboa a bordo do MSC OPERA</p>
                        <p class="text-base md:text-lg text-blue-800 mb-2">Este pack inclui todas as taxas pagas + pack de bebidas</p>
                        <p class="text-base md:text-lg text-blue-800 mb-2 font-semibold">Rota: PORTUGAL-ESPANHA-ITALIA-FRANÇA-ESPANHA-PORTUGAL</p>
                        <p class="text-base md:text-lg text-blue-800 mb-2"><strong>Valor:</strong> 1€ por rifa</p>
                        <p class="text-sm md:text-base text-blue-700 mt-4">Sorteio em direto, jornal local e TV local no fim da missa dia 02/05/2026 - 18h00</p>
                    </div>
                </div>

                <div>
                    <h3 class="text-xl md:text-2xl font-bold text-blue-900 mb-6">Itinerário Detalhado</h3>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div class="border-l-4 border-yellow-400 pl-4">
                            <h4 class="font-bold text-blue-900">Dia 1: 07 Junho - Lisboa, Portugal</h4>
                            <p class="text-blue-800">Partida às 18h00.</p>
                        </div>
                        <div class="border-l-4 border-yellow-400 pl-4">
                            <h4 class="font-bold text-blue-900">Dia 2: 08 Junho - Navegação</h4>
                            <p class="text-blue-800">Dia de relaxamento a bordo.</p>
                        </div>
                        <div class="border-l-4 border-yellow-400 pl-4">
                            <h4 class="font-bold text-blue-900">Dia 3: 09 Junho - Alicante, Espanha</h4>
                            <p class="text-blue-800">Chegada às 09h00, partida às 17h00.</p>
                        </div>
                        <div class="border-l-4 border-yellow-400 pl-4">
                            <h4 class="font-bold text-blue-900">Dia 4: 10 Junho - Mahon, Menorca, Espanha</h4>
                            <p class="text-blue-800">Chegada às 09h00, partida às 16h00.</p>
                        </div>
                        <div class="border-l-4 border-yellow-400 pl-4">
                            <h4 class="font-bold text-blue-900">Dia 5: 11 Junho - Olbia, Itália</h4>
                            <p class="text-blue-800">Chegada às 10h00, partida às 19h00.</p>
                        </div>
                        <div class="border-l-4 border-yellow-400 pl-4">
                            <h4 class="font-bold text-blue-900">Dia 6: 12 Junho - Genova, Itália</h4>
                            <p class="text-blue-800">Chegada às 09h00, partida às 18h00.</p>
                        </div>
                        <div class="border-l-4 border-yellow-400 pl-4">
                            <h4 class="font-bold text-blue-900">Dia 7: 13 Junho - Marselha, França</h4>
                            <p class="text-blue-800">Chegada às 09h00, partida às 17h00.</p>
                        </div>
                        <div class="border-l-4 border-yellow-400 pl-4">
                            <h4 class="font-bold text-blue-900">Dia 8: 14 Junho - Navegação</h4>
                            <p class="text-blue-800">Dia de relaxamento a bordo.</p>
                        </div>
                        <div class="border-l-4 border-yellow-400 pl-4">
                            <h4 class="font-bold text-blue-900">Dia 9: 15 Junho - Málaga, Espanha</h4>
                            <p class="text-blue-800">Chegada às 08h00, partida às 18h00.</p>
                        </div>
                        <div class="border-l-4 border-yellow-400 pl-4">
                            <h4 class="font-bold text-blue-900">Dia 10: 16 Junho - Cádis, Espanha</h4>
                            <p class="text-blue-800">Chegada às 07h00, partida às 17h00.</p>
                        </div>
                        <div class="border-l-4 border-yellow-400 pl-4">
                            <h4 class="font-bold text-blue-900">Dia 11: 17 Junho - Lisboa, Portugal</h4>
                            <p class="text-blue-800">Desembarque às 09h00.</p>
                        </div>
                    </div>
                    <div class="mt-6">
                        <img src="/Rifas/itinerario.webp" alt="Mapa do Itinerário do Cruzeiro" class="rounded-xl w-full h-auto shadow-md">
                    </div>
                </div>




            </div>
        </div>
    </div>

    <!-- Purchase Instructions Modal -->
    <div id="purchase-modal" class="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50 hidden transition-opacity duration-300 ease-in-out opacity-0 pointer-events-none">
        <div class="bg-white p-10 rounded-xl shadow-xl max-w-4xl mx-4 max-h-[90vh] overflow-y-auto transform scale-95 transition-transform duration-300 ease-in-out">
            <div class="flex justify-between items-center mb-8">
                <h2 class="text-2xl md:text-3xl font-bold text-blue-900">Instruções de Compra</h2>
                <button id="close-purchase-modal" class="text-blue-900 text-2xl font-bold">&times;</button>
            </div>
            <PurchaseInstructions />
        </div>
    </div>

</BaseLayout>

<script>
const verMaisBtn = document.getElementById('ver-mais-btn');
const modal = document.getElementById('modal');
const closeModal = document.getElementById('close-modal');

const comprarAgoraBtn = document.getElementById('comprar-agora-btn');
const purchaseModal = document.getElementById('purchase-modal');
const closePurchaseModal = document.getElementById('close-purchase-modal');

if (verMaisBtn && modal && closeModal) {
    verMaisBtn.addEventListener('click', () => {
        modal.classList.remove('hidden');
        modal.classList.remove('opacity-0');
        modal.classList.remove('pointer-events-none');
    });

    closeModal.addEventListener('click', () => {
        modal.classList.add('hidden');
        modal.classList.add('opacity-0');
        modal.classList.add('pointer-events-none');
    });

    modal.addEventListener('click', (e) => {
        if (e.target === modal) {
            modal.classList.add('hidden');
            modal.classList.add('opacity-0');
            modal.classList.add('pointer-events-none');
        }
    });
}

if (comprarAgoraBtn && purchaseModal && closePurchaseModal) {
    comprarAgoraBtn.addEventListener('click', () => {
        purchaseModal.classList.remove('hidden');
        purchaseModal.classList.remove('opacity-0');
        purchaseModal.classList.remove('pointer-events-none');
    });

    closePurchaseModal.addEventListener('click', () => {
        purchaseModal.classList.add('hidden');
        purchaseModal.classList.add('opacity-0');
        purchaseModal.classList.add('pointer-events-none');
    });

    purchaseModal.addEventListener('click', (e) => {
        if (e.target === purchaseModal) {
            purchaseModal.classList.add('hidden');
            purchaseModal.classList.add('opacity-0');
            purchaseModal.classList.add('pointer-events-none');
        }
    });
}
</script>
