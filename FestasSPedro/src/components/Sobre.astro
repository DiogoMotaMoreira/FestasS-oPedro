                            <div class={`flex flex-col items-center ${ (categoria.Categoria === "Coordenação") ? "bg-gradient-to-br from-blue-800 to-yellow-200" : (categoria.Categoria === "Patrocinadores Oficiais") ? "bg-white w-full md:w-80 h-32 justify-center overflow-hidden" : "bg-gradient-to-br from-blue-100/90 to-yellow-100/90" } rounded-2xl ${categoria.Categoria === "Patrocinadores Oficiais" ? "p-0" : "p-2 sm:p-6"} shadow-xl border border-white/40 hover:scale-105 transition-transform duration-200`} data-categories={pessoa.Categorias || ""}>
