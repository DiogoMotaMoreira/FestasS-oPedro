---
interface Props {
    type?: 'hero' | 'full';
}

const { type = 'full' } = Astro.props;
---

<div class="group relative bg-white rounded-3xl shadow-xl overflow-hidden hover:shadow-2xl transition-all duration-300 ring-1 ring-white/50 text-left h-full">
    <!-- Sotaque Dourado -->
    <div class="absolute top-0 left-0 w-full h-2 bg-gradient-to-r from-yellow-400 via-yellow-500 to-yellow-600"></div>
    
    <div class="flex flex-col md:flex-row h-full">
        <!-- Imagem -->
        <div class="md:w-5/12 relative overflow-hidden h-56 md:h-auto">
            <img src="/Rifas/MSC-Opera.webp" alt="MSC-Opera" class="w-full h-full object-cover transform group-hover:scale-105 transition-transform duration-700" />
            <div class="absolute top-4 left-4 bg-yellow-400 text-blue-900 text-xs font-bold px-3 py-1 rounded-full shadow-lg uppercase tracking-wider border border-yellow-200">
                Grande Prémio
            </div>
        </div>
        
        <!-- Conteúdo -->
        <div class="md:w-7/12 p-6 md:p-8 flex flex-col justify-between bg-white">
            <div>
                <div class="flex justify-between items-start mb-2">
                    <h3 class="text-2xl font-bold text-blue-900 leading-tight">Cruzeiro Mediterrâneo</h3>
                </div>
                <p class="text-blue-600 font-medium mb-4 flex items-center gap-2 text-sm">
                    <span class="inline-block w-2 h-2 rounded-full bg-yellow-400"></span>
                    07 a 17 de Junho 2026
                </p>
                
                <p class="text-gray-600 mb-6 leading-relaxed text-sm md:text-base">
                    Embarque numa viagem de sonho de 11 dias a bordo do MSC OPERA. Partida de Lisboa com tudo incluído.
                </p>

                {type === 'full' && (
                    <div class="bg-blue-50/80 p-4 rounded-xl border border-blue-100 mb-6 hidden md:block">
                        <p class="text-xs text-blue-500 font-bold uppercase tracking-wide mb-1">Itinerário</p>
                        <p class="text-sm md:text-base text-blue-900 font-medium">Portugal • Espanha • Itália • França</p>
                    </div>
                )}
            </div>

            <div class="flex flex-col sm:flex-row items-center justify-between gap-4 pt-4 border-t border-gray-100">
                <div class="text-center sm:text-left">
                    <p class="text-xs text-gray-500 uppercase font-semibold tracking-wide">Preço por Rifa</p>
                    <div class="flex items-baseline gap-1 justify-center sm:justify-start">
                        <span class="text-3xl font-bold text-blue-900">1,00€</span>
                    </div>
                    {type === 'full' && <p class="text-[10px] text-gray-400 mt-1">Sorteio: 02/05/2026 às 18h00</p>}
                </div>
                
                {type === 'hero' ? (
                    <a href="/bilheteira" class="w-full sm:w-auto px-8 py-3 rounded-xl bg-gradient-to-r from-blue-900 to-blue-800 text-white font-bold shadow-lg shadow-blue-900/20 hover:shadow-blue-900/40 hover:-translate-y-0.5 transition-all text-center">
                        Comprar Agora
                    </a>
                ) : (
                    <div class="flex gap-3 w-full sm:w-auto"> 
                        <button id="ver-mais-btn" class="flex-1 sm:flex-none px-6 py-3 rounded-xl border-2 border-blue-100 text-blue-900 font-bold hover:bg-blue-50 hover:border-blue-200 transition-colors">
                            + Detalhes
                        </button>
                        
                        <button id="comprar-agora-btn" class="flex-1 sm:flex-none px-8 py-3 rounded-xl bg-gradient-to-r from-blue-900 to-blue-800 text-white font-bold shadow-lg shadow-blue-900/20 hover:shadow-blue-900/40 hover:-translate-y-0.5 transition-all">
                            Comprar Agora
                        </button>
                    </div>
                )}
            </div>
        </div>
    </div>
</div>