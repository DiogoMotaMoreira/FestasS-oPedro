const equipaGroup = grupo.find(g => g.Categoria === "Equipa");
const categoriasSet = new Set();
if (equipaGroup) {
    equipaGroup.Pessoas.forEach(p => {
        if (p.Categorias) p.Categorias.split(',').forEach(c => categoriasSet.add(c.trim()));
    });
}
const categoriasUnicas = Array.from(categoriasSet).sort();

const coordenacao = grupo.find(g => g.Categoria === "Coordenação")?.Pessoas || [];
const equipa = grupo.find(g => g.Categoria === "Equipa")?.Pessoas || [];
const patrocinadores = grupo.find(g => g.Categoria === "Patrocinadores Oficiais")?.Pessoas || [];
const topApoiadores = grupo.find(g => g.Categoria === "Top 6 Apoiadores")?.Pessoas || [];
