            <!-- Patrocinadores Oficiais (Logos Menores) -->
            {patrocinadores.length > 0 ? (
                <div>
                    <h3 class="text-sm font-black uppercase tracking-widest text-gray-400 text-center mb-6">Patrocinadores Oficiais</h3>
                    <div class="flex flex-wrap justify-center gap-4 md:gap-6">
                        {patrocinadores.map(pat => (
                            <div class="w-28 h-20 md:w-40 md:h-24 bg-white rounded-2xl shadow border border-gray-50 p-4 flex items-center justify-center hover:scale-105 transition-transform duration-300 group">
