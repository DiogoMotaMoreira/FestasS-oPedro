---
import Contador from './Contador.astro';
import RifaCard from './RifaCard.astro';
import Popups from './Popups.astro';
---

<div class="relative min-h-screen flex flex-col items-center justify-center px-6 md:px-12 bg-gradient-to-br from-blue-500 via-blue-200 to-yellow-400">
    <!-- Carousel Banner -->
<main class="carousel relative overflow-hidden w-full flex-1 flex items-center max-w-full h-[600px] md:h-[700px]">
        <div class="slides flex flex-row items-center transition-transform duration-500 h-full w-full" id="slides">
            
            <!-- Slide 1: Welcome -->
            <div class="slide flex-shrink-0 w-full flex flex-col items-center justify-center text-center px-6">
                <!-- Logo central -->
                <img src="/sp_logo.webp" alt="Logo Festas São Pedro" class="max-w-[280px] md:max-w-[400px] w-full h-auto" />

                <!-- Datas -->
                <p class="text-2xl md:text-3xl text-blue-900 font-bold drop-shadow-md mt-4">
                    29 de Junho
                </p>
                <p class="text-2xl md:text-3xl text-blue-900 font-bold drop-shadow-md mb-4">
                    2 - 5 de Julho
                </p>

                <!-- Contador -->
                <Contador />
            </div>

            <!-- Slide 2: Rifas -->
            <div class="slide flex-shrink-0 flex-grow-0 basis-full flex flex-col items-center justify-center text-center px-6 py-4 max-w-full overflow-x-hidden">
                <div class="w-full max-w-4xl mx-auto">
                    <RifaCard type="hero" />
                </div>
            </div>

            <!-- Slide 3: Cartaz -->
            <div class="slide flex-shrink-0 flex-grow-0 basis-full flex flex-col items-center justify-center text-center px-6 py-4 max-w-full overflow-x-hidden">
                <div class="w-full max-w-4xl mx-auto">
                    <div class="group relative bg-white rounded-3xl shadow-xl overflow-hidden hover:shadow-2xl transition-all duration-300 ring-1 ring-white/50 text-left">
                        <!-- Sotaque Azul -->
                        <div class="absolute top-0 left-0 w-full h-2 bg-gradient-to-r from-blue-400 via-blue-600 to-blue-800"></div>
                        
                        <div class="flex flex-col md:flex-row">
                            <!-- Imagem -->
                            <div class="md:w-5/12 relative overflow-hidden h-56 md:h-auto">
                                <img src="/cartaz.png" alt="Cartaz 2026" class="w-full h-full object-cover object-top transform group-hover:scale-105 transition-transform duration-700" />
                                <div class="absolute top-4 left-4 bg-blue-600 text-white text-xs font-bold px-3 py-1 rounded-full shadow-lg uppercase tracking-wider border border-blue-400">
                                    Novidade
                                </div>
                            </div>
                            
                            <!-- Conteúdo -->
                            <div class="md:w-7/12 p-6 md:p-8 flex flex-col justify-center bg-white">
                                <div>
                                    <h3 class="text-3xl font-bold text-blue-900 leading-tight mb-2">Cartaz Oficial 2026</h3>
                                    <p class="text-blue-600 font-medium mb-4 flex items-center gap-2">
                                        <span class="inline-block w-2 h-2 rounded-full bg-blue-600"></span>
                                        Já disponível!
                                    </p>
                                    
                                    <p class="text-gray-600 mb-8 leading-relaxed">
                                        Conheça os artistas e a programação completa das Festas de São Pedro 2026. Prepare-se para dias inesquecíveis!
                                    </p>
                                    
                                    <div class="flex gap-4">
                                        <a href="/cartaz" class="w-full px-8 py-3 rounded-xl bg-gradient-to-r from-blue-900 to-blue-800 text-white font-bold shadow-lg shadow-blue-900/20 hover:shadow-blue-900/40 hover:-translate-y-0.5 transition-all text-center">
                                            Ver Cartaz Completo
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Navigation Dots -->
        <div class="absolute bottom-6 left-1/2 transform -translate-x-1/2 flex space-x-2 z-10" id="dots">
            <button class="w-4 h-4 bg-white rounded-full opacity-50 hover:opacity-100 transition" data-slide="0"></button>
            <button class="w-4 h-4 bg-white/50 rounded-full opacity-50 hover:opacity-100 transition" data-slide="1"></button>
            <button class="w-4 h-4 bg-white/50 rounded-full opacity-50 hover:opacity-100 transition" data-slide="2"></button>
        </div>
    </main>

    <Popups />
</div>

<script>
// Carousel functionality
const slides = document.getElementById('slides') as HTMLElement | null;
const dots = document.querySelectorAll('#dots button') as NodeListOf<HTMLButtonElement>;

if (slides && dots.length > 0) {
  let currentSlide = 0;

  function showSlide(index: number) {
    if (slides) {
      console.log('Sliding to index:', index);
      console.log('Slides container:', slides);
      console.log('Slides children:', slides.children);
      slides.style.transform = `translateX(-${index * 100}%)`;
    }
    dots.forEach((dot, i) => {
      dot.classList.toggle('bg-white', i === index);
      dot.classList.toggle('bg-white/50', i !== index);
    });
  }

  // Show initial slide
  showSlide(currentSlide);

  dots.forEach((dot, index) => {
    dot.addEventListener('click', () => {
      currentSlide = index;
      showSlide(currentSlide);
    });
  });

  // Auto slide every 5 seconds
  setInterval(() => {
    currentSlide = (currentSlide + 1) % dots.length;
    showSlide(currentSlide);
  }, 5000);
}
</script>
