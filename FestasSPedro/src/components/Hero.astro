---
import Contador from './Contador.astro';
import RifaCard from './RifaCard.astro';
import Popups from './Popups.astro';
---

<div class="relative min-h-screen flex flex-col items-center justify-center bg-gradient-to-br from-blue-500 via-blue-200 to-yellow-400 font-sans selection:bg-yellow-200 selection:text-blue-900 overflow-hidden">

    <!-- Carousel Banner -->
    <main class="carousel relative w-full flex-1 flex items-center max-w-full min-h-[600px] z-10">
        <div class="slides flex flex-row items-center transition-transform duration-500 h-full w-full" id="slides">
            
            <!-- Slide 1: Welcome -->
            <div class="slide flex-shrink-0 w-full flex flex-col items-center justify-center text-center px-6 md:px-12 relative z-10">
                <span class="text-blue-800 tracking-widest uppercase mb-6 block font-bold text-sm md:text-base drop-shadow-sm">29 Junho — 02 a 05 Julho, 2026</span>
                
                <!-- Logo central -->
                <img src="/sp_logo.webp" alt="Logo Festas São Pedro" class="max-w-[280px] md:max-w-[380px] w-full h-auto mb-6 drop-shadow-xl" />

                <h1 class="font-black text-4xl md:text-6xl text-blue-900 leading-[0.9] tracking-tighter mb-10 drop-shadow-sm">
                    <span class="text-yellow-500">Festas</span> de São Pedro
                </h1>

                <!-- Contador -->
                <Contador />
            </div>

            <!-- Slide 2: Rifas -->
            <div class="slide flex-shrink-0 w-full flex flex-col items-center justify-center text-center px-6 md:px-12 py-4 max-w-full overflow-x-hidden">
                <div class="w-full max-w-4xl mx-auto">
                    <RifaCard type="hero" />
                </div>
            </div>

            <!-- Slide 3: Cartaz -->
            <div class="slide flex-shrink-0 w-full flex flex-col items-center justify-center text-center px-6 md:px-12 py-4 max-w-full overflow-x-hidden">
                <div class="w-full max-w-4xl mx-auto">
                    <div class="group relative bg-[#f6fafe] rounded-[2rem] shadow-[0_20px_50px_rgba(0,35,111,0.1)] overflow-hidden hover:-translate-y-2 transition-all duration-500 ring-1 ring-blue-900/5 text-left">
                        <div class="flex flex-col md:flex-row">
                            <!-- Imagem -->
                            <div class="md:w-5/12 relative overflow-hidden h-64 md:h-auto">
                                <img src="/cartaz.png" alt="Cartaz 2026" class="w-full h-full object-cover object-top transform group-hover:scale-110 transition-transform duration-700" />
                                <div class="absolute top-6 left-6 bg-[#fed01b] text-[#6f5900] text-xs font-bold px-4 py-1.5 rounded uppercase tracking-wider shadow-lg">
                                    Novidade
                                </div>
                            </div>
                            
                            <!-- Conteúdo -->
                            <div class="md:w-7/12 p-8 md:p-12 flex flex-col justify-center bg-white">
                                <div>
                                    <h3 class="text-4xl md:text-5xl font-black text-[#00236f] tracking-tighter mb-4 leading-tight">Cartaz Oficial 2026</h3>
                                    <p class="text-[#00236f]/70 font-bold mb-6 flex items-center gap-2 uppercase tracking-widest text-sm">
                                        <span class="inline-block w-2 h-2 rounded-full bg-[#fed01b]"></span>
                                        Já disponível!
                                    </p>
                                    
                                    <p class="text-[#444651] mb-10 leading-relaxed text-lg">
                                        Conheça os artistas e a programação completa das Festas de São Pedro 2026. Prepare-se para dias inesquecíveis!
                                    </p>
                                    
                                    <div>
                                        <a href="/cartaz" class="inline-flex items-center justify-center w-full md:w-auto px-10 py-4 rounded-xl bg-[#00236f] text-white font-bold text-lg uppercase tracking-tight hover:bg-[#001a42] transition-all shadow-xl shadow-[#00236f]/20 hover:shadow-[#00236f]/40 hover:-translate-y-1">
                                            Ver Cartaz Completo
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Navigation Dots -->
        <div class="absolute bottom-10 left-1/2 transform -translate-x-1/2 flex items-center space-x-3 z-20" id="dots">
            <button class="w-4 h-3 rounded-full bg-yellow-400 shadow-md transition-all duration-300" data-slide="0"></button>
            <button class="w-3 h-3 rounded-full bg-blue-900/20 hover:bg-blue-900/40 transition-all duration-300" data-slide="1"></button>
            <button class="w-3 h-3 rounded-full bg-blue-900/20 hover:bg-blue-900/40 transition-all duration-300" data-slide="2"></button>
        </div>
    </main>

    <Popups />
</div>

<script>
// Carousel functionality
const slides = document.getElementById('slides') as HTMLElement | null;
const dots = document.querySelectorAll('#dots button') as NodeListOf<HTMLButtonElement>;

if (slides && dots.length > 0) {
  let currentSlide = 0;

  function showSlide(index: number) {
    if (slides) {
      slides.style.transform = `translateX(-${index * 100}%)`;
    }
    dots.forEach((dot, i) => {
          if (i === index) {
            dot.className = 'w-4 h-3 rounded-full bg-yellow-400 shadow-md transition-all duration-300';
          } else {
            dot.className = 'w-3 h-3 rounded-full bg-blue-900/20 hover:bg-blue-900/40 transition-all duration-300 cursor-pointer';
          }
    });
  }

  // Show initial slide
  showSlide(currentSlide);

  dots.forEach((dot, index) => {
    dot.addEventListener('click', () => {
      currentSlide = index;
      showSlide(currentSlide);
    });
  });

  // Auto slide every 5 seconds
  setInterval(() => {
    currentSlide = (currentSlide + 1) % dots.length;
    showSlide(currentSlide);
  }, 5000);
}
</script>
