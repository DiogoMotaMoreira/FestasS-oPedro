            </section>
        )}

        <!-- Patrocinadores -->
        <section class="mt-12 bg-white/80 backdrop-blur-md rounded-[3rem] p-8 md:p-12 shadow-2xl border border-white/50">
            <div class="text-center space-y-4 mb-12">
                <h2 class="text-3xl md:text-5xl font-black text-blue-900 tracking-tight">
                    Os Nossos <span class="text-yellow-500 drop-shadow-sm">Parceiros</span>
                </h2>
                <p class="text-blue-800/80 font-medium max-w-2xl mx-auto">
                    Um agradecimento especial às empresas que tornam as Festas de São Pedro possíveis. O seu apoio é fundamental.
                </p>
            </div>

            <!-- Top Apoiadores (Logos Maiores) -->
            {topApoiadores.length > 0 && (
                <div class="mb-12">
                    <h3 class="text-sm font-black uppercase tracking-widest text-gray-400 text-center mb-6">Top Apoiadores</h3>
                    <div class="flex flex-wrap justify-center gap-6 md:gap-10">
                        {topApoiadores.map(pat => (
                            <div class="w-40 h-40 md:w-56 md:h-56 bg-white rounded-3xl shadow-lg border border-gray-100 p-6 flex items-center justify-center hover:scale-105 transition-transform duration-300">
                                {pat.Foto ? <img src={pat.Foto} alt={pat.Nome} class="max-w-full max-h-full object-contain" /> : <span class="font-bold text-gray-300 text-center">{pat.Nome}</span>}
