<div class="min-h-screen relative flex flex-col items-center pt-32 pb-20 px-4 sm:px-6 md:px-12 bg-gradient-to-br from-blue-500 via-blue-200 to-yellow-400 selection:bg-yellow-200 selection:text-blue-900">
    
    <!-- Cabeçalho -->
    <div class="text-center space-y-4 mb-16 z-10 w-full max-w-4xl">
        <h1 class="text-5xl md:text-7xl font-black text-blue-900 drop-shadow-sm tracking-tight">
            Sobre <span class="text-yellow-500 drop-shadow-md">Nós</span>
        </h1>
        <p class="text-lg md:text-xl text-blue-900/80 font-medium drop-shadow-sm">
            Somos a alma das Festas de São Pedro de Caíde de Rei — um grupo de amigos, vizinhos e apaixonados pelas tradições que trabalha para manter viva a chama da nossa cultura.
        </p>
    </div>

    <div class="w-full max-w-7xl flex flex-col gap-20 z-10">
        
        <!-- Coordenação -->
        {coordenacao.length > 0 && (
            <section class="space-y-8">
                <h2 class="text-3xl md:text-4xl font-extrabold text-blue-900 text-center flex items-center justify-center gap-3">
                    <span class="w-8 h-1 bg-yellow-400 rounded-full"></span>
                    Coordenação
                    <span class="w-8 h-1 bg-yellow-400 rounded-full"></span>
                </h2>
                
                <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6 md:gap-8">
                    {coordenacao.map((pessoa) => (
                        <div class="bg-white/80 backdrop-blur-md rounded-3xl p-6 md:p-8 shadow-xl border border-white/50 hover:-translate-y-2 transition-transform duration-300 flex flex-col items-center text-center group">
                            <div class="w-32 h-32 md:w-40 md:h-40 rounded-full mb-6 p-1 bg-gradient-to-tr from-yellow-400 to-blue-600 shadow-lg group-hover:scale-105 transition-transform duration-300">
                                <img src={pessoa.Foto || '/sp_logo.webp'} alt={pessoa.Nome} class="w-full h-full object-cover rounded-full border-4 border-white bg-white" />
                            </div>
                            <h3 class="text-2xl font-black text-blue-900 mb-2">{pessoa.Nome}</h3>
                            <div class="flex flex-wrap justify-center gap-2 mt-2">
                                {pessoa.Categorias?.split(', ').map(cat => (
                                    <span class="px-3 py-1 bg-blue-100 text-blue-800 rounded-full text-xs font-bold uppercase tracking-wider">{cat}</span>
                                ))}
                            </div>
                        </div>
                    ))}
                </div>
            </section>
        )}

        <!-- Equipa -->
        {equipa.length > 0 && (
            <section class="space-y-8">
                <div class="text-center space-y-4">
                    <h2 class="text-3xl md:text-4xl font-extrabold text-blue-900 flex items-center justify-center gap-3">
                        <span class="w-8 h-1 bg-yellow-400 rounded-full"></span>
                        A Nossa Equipa
                        <span class="w-8 h-1 bg-yellow-400 rounded-full"></span>
                    </h2>
                    <p class="text-blue-800 font-medium">Conheça todos os que fazem a festa acontecer.</p>
                </div>

                <!-- Filtro em Dropdown Suspenso -->
                <div class="w-full relative">
                    <div class="w-full max-w-sm mx-auto relative">
                        <select id="equipa-filter" class="w-full appearance-none bg-white/80 backdrop-blur-md border border-white/50 text-blue-900 font-bold text-base py-3 pl-6 pr-12 rounded-full shadow-md focus:outline-none focus:ring-4 focus:ring-blue-900/20 transition-all cursor-pointer text-center text-center-last">
